# Copy to .env for local RAG usage.

# Required only for commands/ask.py.
OPENAI_API_KEY=

# Optional.
OPENAI_MODEL=gpt-4.1-mini
QDRANT_URL=http://localhost:6333
# Optional. Use QDRANT_URL=local to force local mode.
# If unset, local fallback writes to IceBot-Tools/data/qdrant_local.
QDRANT_LOCAL_PATH=
RAG_CACHE_ROOT=
# FASTEMBED_CACHE_PATH is set automatically to CACHE_ROOT/fastembed.
# CACHE_ROOT comes from RAG_CACHE_ROOT or defaults to ~/.cache/icebot-rag.
# Set explicitly to override if needed.
# FASTEMBED_CACHE_PATH=
RAG_LOG_DIR=
RAG_LOG_MAX_BYTES=10485760
RAG_LOG_BACKUP_COUNT=10
RAG_LOG_CONSOLE=false

# Collection versioning.
# Docs and code use separate collections so source code does not dominate docs retrieval.
# Bump the relevant version when changing embedding model/dimension or chunking strategy.
RAG_DOCS_COLLECTION_BASE_NAME=icebot_docs_knowledge
RAG_DOCS_COLLECTION_VERSION=v1
# RAG_DOCS_COLLECTION_NAME=icebot_docs_knowledge_v1

RAG_CODE_COLLECTION_BASE_NAME=icebot_code_knowledge
RAG_CODE_COLLECTION_VERSION=v1
# RAG_CODE_COLLECTION_NAME=icebot_code_knowledge_v1

# Embedding/sparse/reranker model settings.
RAG_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
RAG_SPARSE_MODEL=Qdrant/bm25
RAG_ENABLE_HYBRID=true
RAG_HYBRID_RRF_K=60
RAG_RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B

# Markdown chunking.
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120

# Retrieval safety limits.
RAG_MAX_RETRIEVAL_LIMIT=10
RAG_MAX_CANDIDATE_LIMIT=100
