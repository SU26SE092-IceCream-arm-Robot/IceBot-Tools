# Copy to .env for local RAG usage.

# Required only for commands/ask.py.
OPENAI_API_KEY=

# Optional.
OPENAI_MODEL=gpt-4.1-mini
QDRANT_URL=http://localhost:6333
RAG_CACHE_ROOT=
RAG_LOG_DIR=
RAG_LOG_MAX_BYTES=10485760
RAG_LOG_BACKUP_COUNT=10
RAG_LOG_CONSOLE=false

# Collection versioning.
# Keep the base name logical; bump the version when changing embedding model/dimension.
RAG_COLLECTION_BASE_NAME=icebot_project_knowledge
RAG_COLLECTION_VERSION=v1
# RAG_COLLECTION_NAME=icebot_project_knowledge_v1

# Embedding/reranker model settings.
RAG_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
RAG_RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B

# Markdown chunking.
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120

# Retrieval safety limits.
RAG_MAX_RETRIEVAL_LIMIT=10
RAG_MAX_CANDIDATE_LIMIT=100
